# Uncomment this line to define a global platform for your project
# platform :ios, '13.0'

# 使用 CDN（增量拉取）；勿用 github.com/CocoaPods/Specs.git 全量仓库，CI 上易超时（curl 大文件中断）。
source 'https://cdn.cocoapods.org/'
# Flutter 与插件（如 yunxin_alog）要求不低于 iOS 13；勿低于 11 或与 post_install 冲突
platform :ios, '13.0'

# Xcode 15+：不向 Embed/Copy 脚本挂 input/output xcfilelist，避免同一产物路径被登记两次 → Multiple commands produce
install! 'cocoapods', :disable_input_output_paths => true

# IM + 互动直播 + 音视频通话：与官方可运行示例 nim-uikit-flutter-room/im_demo/ios/Podfile 对齐（云信工单回复）。
# Pod.const_set + NIMSDK_LITE/FCS + NERtcSDK 固定版本，避免 nim_core_v2 iOS 侧 Swift 类型（如 V2NIMPostscript）与原生 SDK 不匹配。
# 勿再单独写 pod 'NIMSDK', '10.9.x'（与 Dart 包版本号易混）；勿在 CI 里把 NERtcSDK 从 5.9.11 改成 5.9.10，会与下方 pin 冲突。

ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

# 在 [CP] Embed / Copy Pods 脚本前执行去重，避免 flutter build 内部再次 pod install 后仍产生重复产物路径
def inject_dedupe_before_cocoapods_embed(installer)
  ios_dir = File.dirname(File.realpath(__FILE__))
  marker = 'dedupe_cocoapods_embed.rb'
  # PODS_ROOT = ios/Pods，上一级即 ios，脚本与 Podfile 同目录（比 SRCROOT 更稳）
  prefix = "ruby \"${PODS_ROOT}/../#{marker}\" \"${PODS_ROOT}\" && "

  project = installer.aggregate_targets.map(&:user_project).compact.first

  if project.nil?
    xcodeproj = File.join(ios_dir, 'Runner.xcodeproj')
    project = Xcodeproj::Project.open(xcodeproj) if File.exist?(xcodeproj)
  end
  return if project.nil?

  project.targets.each do |target|
    next unless target.name == 'Runner'

    target.build_phases.each do |phase|
      next unless phase.is_a?(Xcodeproj::Project::Object::PBXShellScriptBuildPhase)
      next unless phase.name && ['[CP] Embed Pods Frameworks', '[CP] Copy Pods Resources'].include?(phase.name)

      # 双保险：清空 file list（若 CocoaPods 版本仍写入）
      phase.input_file_list_paths = [] if phase.respond_to?(:input_file_list_paths=)
      phase.output_file_list_paths = [] if phase.respond_to?(:output_file_list_paths=)

      script = phase.shell_script.to_s
      next if script.include?(marker)

      phase.shell_script = prefix + script
    end
  end
  project.save
end

target 'Runner' do
  # 勿用 use_frameworks! :linkage => :static：NERoomKit / NECoreIM2Kit 编译时需要 NIMSDK 以 module 形式可见，
  # 静态链接常见报错：module 'NIMSDK' not found / could not build module 'NERoomKit'。
  # 重复嵌入由 install! :disable_input_output_paths 与 dedupe_cocoapods_embed.rb 缓解。
  use_frameworks!
  use_modular_headers!
  pod 'GCDWebServer', '3.5.4'

  Pod.const_set(:SPECIAL_VERSION, true)
  Pod.const_set(:FCS_SPECIAL_VERSION, true)
  pod 'NIMSDK_LITE/FCS', '10.9.81'
  pod 'NERtcSDK', '5.9.11'

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
end


post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
        target.build_configurations.each do |config|
         config.build_settings["EXCLUDED_ARCHS[sdk=iphonesimulator*]"] = "arm64"
         config.build_settings['EXPANDED_CODE_SIGN_IDENTITY'] = ""
         config.build_settings['CODE_SIGNING_REQUIRED'] = "NO"
         config.build_settings['CODE_SIGNING_ALLOWED'] = "NO"
         config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '13.0'
         # Xcode 15+/Swift 6：显式模块扫描与云信 NERoomKit/NIMSDK 等 XCFramework 组合时易出现
         # Clang dependency scanner / module 'NIMSDK' not found（与是否 static linkage 无关）
         config.build_settings['SWIFT_ENABLE_EXPLICIT_MODULES'] = 'NO'
         # 云信反馈当前仅支持 Swift 5，统一设置 Pods target 的 Swift 语言版本
         config.build_settings['SWIFT_VERSION'] = '5.0'
         config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] ||= [
             '$(inherited)',

             ## dart: PermissionGroup.calendar
             # 'PERMISSION_EVENTS=0',

             ## dart: PermissionGroup.reminders
             # 'PERMISSION_REMINDERS=0',

             ## dart: PermissionGroup.contacts
             # 'PERMISSION_CONTACTS=0',

             # dart: PermissionGroup.camera
             'PERMISSION_CAMERA=1',

             # dart: PermissionGroup.microphone
             'PERMISSION_MICROPHONE=1',

             ## dart: PermissionGroup.speech
             # 'PERMISSION_SPEECH_RECOGNIZER=0',

             # dart: PermissionGroup.photos
             'PERMISSION_PHOTOS=1',

             ## dart: [PermissionGroup.location, PermissionGroup.locationAlways, PermissionGroup.locationWhenInUse]
             'PERMISSION_LOCATION=1',

             ## dart: PermissionGroup.notification
             # 'PERMISSION_NOTIFICATIONS=0',

             # dart: PermissionGroup.mediaLibrary
             'PERMISSION_MEDIA_LIBRARY=1',

             ## dart: PermissionGroup.sensors
             # 'PERMISSION_SENSORS=0',

             ## dart: PermissionGroup.bluetooth
             # 'PERMISSION_BLUETOOTH=0'
           ]
         # 与 platform :ios 一致；勿再 delete，否则 CocoaPods 与 Flutter 对最低系统版本不一致

         #https://stackoverflow.com/a/77134628/5734049
         xcconfig_path = config.base_configuration_reference.real_path
         xcconfig = File.read(xcconfig_path)
         xcconfig_mod = xcconfig.gsub(/DT_TOOLCHAIN_DIR/, "TOOLCHAIN_DIR")
         File.open(xcconfig_path, "w") { |file| file << xcconfig_mod }
         end

  end

  installer.aggregate_targets.each do |aggregate_target|
    next unless aggregate_target.user_project

    aggregate_target.user_project.targets.each do |t|
      t.build_configurations.each do |config|
        config.build_settings['SWIFT_ENABLE_EXPLICIT_MODULES'] = 'NO'
        config.build_settings['SWIFT_VERSION'] = '5.0'
      end
    end
    aggregate_target.user_project.save
  end

  # Xcode 15+：nim_core + roomkit 等对 NIMSDK 重复嵌入、资源重复产出 Assets.car → Multiple commands produce
  # 按「产物 basename」对 xcfilelist 成对去重（见 dedupe_cocoapods_embed.rb）。
  dedupe_rb = File.expand_path('dedupe_cocoapods_embed.rb', File.dirname(__FILE__))
  if File.exist?(dedupe_rb)
    system('ruby', dedupe_rb, installer.sandbox.root.to_s) || raise("dedupe_cocoapods_embed.rb failed")
  end

  inject_dedupe_before_cocoapods_embed(installer)
end
